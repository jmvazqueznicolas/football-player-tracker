# --------------------------------------------------------------
# Copy this file to .env and fill in real values. Never commit .env
# --------------------------------------------------------------

# ----- GCP -----
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET=football-tracker-artifacts
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# ----- MLflow -----
# Local tracking (SQLite — required for Model Registry):
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# Remote tracking: postgresql://user:pass@host/db  or  http://mlflow-server:5000
MLFLOW_ARTIFACT_LOCATION=gs://football-tracker-artifacts/mlflow
MLFLOW_EXPERIMENT_NAME=football-player-tracker

# ----- Weights & Biases -----
# Get key from https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=football-player-tracker
WANDB_ENTITY=your_wandb_username

# ----- Roboflow (for dataset download) -----
ROBOFLOW_API_KEY=your_roboflow_key_here

# ----- DVC remote -----
DVC_REMOTE_URL=gs://football-tracker-artifacts/dvc

# ----- Hugging Face (for demo deploy) -----
HF_TOKEN=your_hf_token_here
HF_SPACE_NAME=USERNAME/football-player-tracker

# ----- App configuration -----
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
